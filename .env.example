# ============================================================
# 环境变量配置示例
# 复制此文件为 .env.local（本地开发）或在 Vercel 项目设置中配置
# ============================================================

# GitHub OAuth App 的 Client ID（前端可见，不敏感）
VUE_APP_GITHUB_CLIENT_ID=your_github_oauth_app_client_id

# ============================================================
# 以下变量只在 Vercel Serverless Function 中使用
# 不要加 VUE_APP_ 前缀（否则会暴露到前端）
# 在 Vercel 项目设置 → Environment Variables 中配置
# ============================================================

# GitHub OAuth App 的 Client Secret（敏感，只在服务端使用）
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
